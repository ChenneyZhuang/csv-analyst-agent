# CSV Analyst Agent
# Environment Variables — copy to .env and fill in your values
# =====================================================================

# DeepSeek API key (get one at https://platform.deepseek.com/api_keys)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API base URL (change if using a proxy or compatible endpoint)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model to use for analysis (deepseek-chat is the recommended default)
DEEPSEEK_MODEL=deepseek-chat

# Maximum tokens for LLM responses
DEEPSEEK_MAX_TOKENS=4096

# Temperature for LLM generation (0.0 = deterministic, 1.0 = creative)
DEEPSEEK_TEMPERATURE=0.3

# Output directory for generated charts (default: ./charts)
CSV_ANALYST_CHARTS_DIR=./charts

# Maximum rows to sample for LLM analysis (default: 50)
CSV_ANALYST_MAX_SAMPLE_ROWS=50
